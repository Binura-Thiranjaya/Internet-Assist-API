<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS HttpPlatformHandler config for the Internet Assist Flask API.
  Requires: IIS HttpPlatformHandler module installed on the server.
  Download: https://www.iis.net/downloads/microsoft/httpplatformhandler
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="PythonHandler" path="*" verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <!--
      processPath: path to python.exe inside the venv
      IIS spawns this process and proxies all HTTP to it via %HTTP_PLATFORM_PORT%
    -->
    <httpPlatform
        processPath=".\venv\Scripts\python.exe"
        arguments="waitress_server.py"
        stdoutLogEnabled="true"
        stdoutLogFile=".\logs\python_stdout.log"
        startupTimeLimit="120"
        requestTimeout="00:04:00"
        processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="APP_ENV"           value="production" />
        <environmentVariable name="HTTP_PLATFORM_PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatform>

    <!-- Strip server identity headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <remove name="Server" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
